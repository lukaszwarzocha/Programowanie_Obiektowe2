<Window x:Class="WpfAppLab2.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:local="clr-namespace:WpfAppLab2" 
        mc:Ignorable="d" 
        Title="MainWindow" Height="850" Width="1400" 
   

    <Window.Resources>
        <!-- TODO 1: Uzupelnij styl przyciskow podmenu: - wysokosc - margines - kolor tla - rozmiar czcionki -->
        <Style x:Key="SubMenuButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="40"/>
        <Setter Property="Margin" Value="10,4"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="#1E5BB8" />
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,0,0,0"/>
        </Style>
        <!-- TODO 2: Utworz styl dla Expanderow menu bocznego. -->
        <Style x:Key="MenuExpanderStyle" TargetType="Expander">
            <Setter Property="Margin" Value="20px"/>
        <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="IsExpanded" Value="True"/>
        </Style>
    </Window.Resources>
    <Grid>
        <!-- TODO 3: Zdefiniuj 2 kolumny: - lewa kolumna dla menu - prawa kolumna dla zawartosci glownej -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- LEWE MENU -->
        <Border Grid.Column="0" Background="#FF0047A1" CornerRadius="0,18,18,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,10,0,10">
                    <!-- TODO 4: Dodaj sekcje z logo i nazwa projektu -->
                    <StackPanel Margin="0,10,0,20" HorizontalAlignment="Center">
                        <Border Background="White" CornerRadius="40" Padding="8">
                            <Image Height="72" Width="72" Source="/ur.jpg" Stretch="Fill"/>
                        </Border>
                        <TextBlock Text="SMS Project" Foreground="White" FontSize="20" FontWeight="Bold"
HorizontalAlignment="Center" Margin="0,12,0,0"/>
                        <TextBlock Text="Panel główny" Foreground="#FFD9E6FF" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <!-- TODO 5: Utworz Expander Student z trzema przyciskami: - Rejestracja - Zarzadzanie studentami - Drukuj -->
                    <Expander Header="Student" Style="{StaticResource MenuExpanderStyle}" IsExpanded="True">
                        <StackPanel>
                            <Button x:Name="Rejestracja" Content="Rejestracja" Style="{StaticResource SubMenuButtonStyle}"/>
                            <Button x:Name="Zarzadzanie_studentami" Content="Zarzadzanie studentami" Style="{StaticResource SubMenuButtonStyle}"/>
                            <Button x:Name="Drukuj" Content="Drukuj" Style="{StaticResource SubMenuButtonStyle}"/>
                        </StackPanel>
                    </Expander>
                    <!-- TODO 6: Utworz kolejne sekcje: - Kursy - Wyniki - Dashboard-->                   
                    <Expander Header="Kursy" Style="{StaticResource MenuExpanderStyle}">
    <StackPanel>
        <Button Content="Nowy kurs" Style="{StaticResource SubMenuButtonStyle}"/>
        <Button Content="Zarządzaj kursami" Style="{StaticResource SubMenuButtonStyle}"/>
        <Button Content="Drukuj kursy" Style="{StaticResource SubMenuButtonStyle}"/>
    </StackPanel>
</Expander>

<Expander Header="Wyniki" Style="{StaticResource MenuExpanderStyle}">
    <StackPanel>
        <Button Content="Nowy wynik" Style="{StaticResource SubMenuButtonStyle}"/>
        <Button Content="Zarządzaj wynikami" Style="{StaticResource SubMenuButtonStyle}"/>
        <Button Content="Drukuj wyniki" Style="{StaticResource SubMenuButtonStyle}"/>
    </StackPanel>
</Expander>

<Expander Header="Dashboard" Style="{StaticResource MenuExpanderStyle}">
    <StackPanel>
        <Button Content="Dashboard" Style="{StaticResource SubMenuButtonStyle}"/>
        <Button Content="Raporty" Style="{StaticResource SubMenuButtonStyle}"/>
        <Button Content="Statystyki" Style="{StaticResource SubMenuButtonStyle}"/>
    </StackPanel>
</Expander>
                    
                    <!-- TODO 7: Dodaj przycisk Wyjscie na dole menu -->
                    <Button x:Name="Wyjscie" Content="Wyjście" Margin="10,25,10,10" Height="40"
        Background="#E74C3C" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
        <!-- PRAWA CZESC -->
        <Grid Grid.Column="1" Margin="15">
            <!-- TODO 8: Zdefiniuj 3 wiersze: - naglowek gorny - obszar glowny - panel dolny -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="160"/>
            </Grid.RowDefinitions>
            <!-- GORA -->
            <Border Grid.Row="0" Background="White" CornerRadius="18" Padding="22" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <!-- TODO 9: Uzupelnij naglowek: - nazwa uczelni - Witaj: Administrator - Rola: Administrator systemu -->
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Uniwersytet Rzeszowski" FontSize="30" FontWeight="Bold" Foreground="#FF0047A1" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                            <TextBlock Text="Witaj:" FontSize="18" FontWeight="SemiBold" Foreground="#FF1F2D3D"/>
                            <TextBlock x:Name="welcomeUserText" Text="Administrator" FontSize="18" Foreground="#FF1F2D3D" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="Rola:" FontSize="18" FontWeight="SemiBold" Foreground="#FF1F2D3D"/>
                            <TextBlock x:Name="roleText" Text="Administrator systemu" FontSize="18" Foreground="#FF1F2D3D" Margin="8,0,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- TODO 10: Dodaj ikone uzytkownika po prawej stronie -->
                    <Border Grid.Column="1" Width="100" Height="100" Background="#FFEAF1FB" CornerRadius="50" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="Tutaj_ikonka" FontSize="46" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
            <!-- SRODEK -->
            <Border Grid.Row="1" Background="White" CornerRadius="18" Padding="15" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- TODO 11: Dodaj tytul sekcji glownej -->
                    <TextBlock x:Name="sectionTitleText" Text="Panel główny" FontSize="22"
FontWeight="Bold" Foreground="#FF0047A1" VerticalAlignment="Center"/>
                    <!-- TODO 12: Utworz pusty obszar roboczy contentArea -->
                    <Border Grid.Row="1" Background="#FFF7F9FC" CornerRadius="12" BorderBrush="#FFD8E1F0" BorderThickness="1" Padding="10">
                        <Grid x:Name="PanelGlowny"/>
                    </Border>
                </Grid>
            </Border>
            <!-- DOL -->
            <Border Grid.Row="2" Background="#FF0047A1" CornerRadius="18" Padding="22">
                <Grid>
                    <!-- TODO 13: Zdefiniuj 3 kolumny dolnego panelu: - liczba studentow - wybor grupy - statystyki -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- LEWA CZESC -->
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="................................" FontSize="18" Foreground="White" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock Text="Mezczylşni:" Foreground="White" FontSize="16"/>
                            <TextBlock x:Name="maleCountText" Text="0" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="8,0,24,0"/>
                            <TextBlock Text="Kobiety:" Foreground="White" FontSize="16"/>
                            <TextBlock x:Name="femaleCountText" Text="0" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- SRODKOWA CZESC -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="25,0,25,0">
                        <TextBlock Text="................................" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                        <!-- TODO 14: Dodaj ComboBox z nazwa classComboBox i 4 przykladowymi grupami laboratoryjnymi -->
                        <ComboBox x:Name="................................" Height="34" FontSize="15" SelectedIndex="0">
                            <ComboBoxItem Content="INF BSZ Lab 1"/>
                            <ComboBoxItem Content="INF BSZ Lab 2"/>
                            <ComboBoxItem Content="INF PO Lab 1"/>
                            <ComboBoxItem Content="INF PO Lab 2"/>
                        </ComboBox>
                    </StackPanel>
                    <!-- PRAWA CZESC -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Text="................................" FontSize="18" Foreground="White" FontWeight="Bold" HorizontalAlignment="Right"/>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock Text="Meżczyźni:" Foreground="White" FontSize="16"/>
                            <TextBlock Text="0" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="8,0,20,0"/>
                            <TextBlock Text="Kobiety:" Foreground="White"
FontSize="16"/>
                            <TextBlock Text="0" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
