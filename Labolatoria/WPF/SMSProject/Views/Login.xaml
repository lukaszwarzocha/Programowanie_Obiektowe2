<Window x:Class="SMSProject.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SMSProject"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="Login" Height="500" Width="850">
    <Grid>
        <Image HorizontalAlignment="Left" Height="100" Margin="10,10,0,0" VerticalAlignment="Top" Width="100"/>
        <Image Margin="10,10,720,354" Source="/logo_ur.png" Stretch="Fill"/>
        <TextBlock HorizontalAlignment="Left" Margin="146,53,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="35" Width="293" FontSize="24" FontWeight="Bold"><Run Language="pl-pl" Text="Uniwersytet Rzeszowski"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="362,198,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontWeight="Bold" FontSize="16"><Run Language="pl-pl" Text="Login:"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="362,262,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="16" FontWeight="Bold"><Run Language="pl-pl" Text="Hasło"/><Run Text=":"/></TextBlock>
        <PasswordBox HorizontalAlignment="Center" Name="password" Margin="0,292,0,0" VerticalAlignment="Top" Width="126" Height="21"/>
        <TextBox HorizontalAlignment="Center" Name="userName"  Margin="0,227,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="126" TextChanged="TextBox_TextChanged" Height="21"/>
        <Button Content="Zaloguj" Margin="370,340,370,101" Click="Button_Click" Background="#FF0047A1" Foreground="White"/>

    </Grid>
</Window>
