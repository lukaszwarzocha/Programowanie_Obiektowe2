<Window x:Class="SMSProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SMSProject"
        mc:Ignorable="d"
        Title="MainForm"
        Height="996"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#FFF5F7FB">

    <Window.Resources>
        <Style x:Key="SubMenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF1976D2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,0,0,0"/>
        </Style>

        <Style x:Key="MenuExpanderStyle" TargetType="Expander">
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FF0047A1" CornerRadius="0,18,18,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,10">

                    <StackPanel Margin="0,10,0,20" HorizontalAlignment="Center">
                        <Border Background="White" CornerRadius="40" Padding="8">
                            <Image Height="100" Width="100" Source="/logo_ur.png" VerticalAlignment="Top"/>

                        </Border>
                        <TextBlock Text="Student Management System"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0"/>
                        <TextBlock Text="Uniwersytet Rzeszowski"
                                   Foreground="#FFD9E6FF"
                                   FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Expander Header="Student" Style="{StaticResource MenuExpanderStyle}">
                        <StackPanel>
                            <Button x:Name="RegisterStudentButton"
                                    Content="Rejestracja"
                                    
                                    Style="{StaticResource SubMenuButtonStyle}"/>
                            <Button x:Name="ManageStudentsButton"
                                    Content="Zarządzanie studentami"
                                    Style="{StaticResource SubMenuButtonStyle}"/>
                            <Button x:Name="PrintStudentButton"
                                    Content="Drukuj"
                                    Style="{StaticResource SubMenuButtonStyle}"/>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Kursy" Style="{StaticResource MenuExpanderStyle}">
                        <StackPanel>
                            <Button Content="Lista kursów" Style="{StaticResource SubMenuButtonStyle}"/>
                            <Button Content="Przypisz kurs" Style="{StaticResource SubMenuButtonStyle}"/>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Wyniki" Style="{StaticResource MenuExpanderStyle}">
                        <StackPanel>
                            <Button Content="Oceny" Style="{StaticResource SubMenuButtonStyle}"/>
                            <Button Content="Statystyki" Style="{StaticResource SubMenuButtonStyle}"/>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Dashboard" Style="{StaticResource MenuExpanderStyle}">
                        <StackPanel>
                            <Button Content="Panel główny" Style="{StaticResource SubMenuButtonStyle}"/>
                        </StackPanel>
                    </Expander>
                    
                    <Button x:Name="ExitButton"
                            Content="Wyjście"
                            Margin="10,25,10,10"
                            Height="45"
                            Background="#FFB71C1C"
                            Foreground="White"
                            FontSize="18"
                            FontWeight="Bold"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
        
        <Grid Grid.Column="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="160"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" CornerRadius="18" Padding="22" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Uniwersytet Rzeszowski"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#FF0047A1"/>

                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                            <TextBlock Text="Witaj:"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock x:Name="welcomeUserText"
                                       Text="Administrator"
                                       FontSize="18"
                                       Margin="8,0,0,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="Rola:"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock x:Name="roleText"
                                       Text="Administrator systemu"
                                       FontSize="18"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <Border Grid.Column="1" Width="100" Height="100"
                            Background="#FFEAF1FB" CornerRadius="50">
                        <TextBlock Text="Ł"
                                   FontSize="46"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
            
            <Border Grid.Row="1" Background="White" CornerRadius="18" Padding="15" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="sectionTitleText"
                               Text="Panel główny"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#FF0047A1"/>

                    <Border Grid.Row="1" Background="#FFF7F9FC"
                            CornerRadius="12"
                            BorderBrush="#FFD8E1F0"
                            BorderThickness="1"
                            Padding="10">
                        <Grid x:Name="contentArea"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="2" Background="#FF0047A1" CornerRadius="18" Padding="22">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel>
                        <TextBlock Text="Liczba studentów"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0, 0, 0, 50"/>

                        <TextBlock Text="Mężczyźni: 0"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="Bold"/>

                        <TextBlock Text="Kobiety: 0"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="Bold"/>

                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Grupa laboratoryjna"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>
                        <ComboBox x:Name="classComboBox"
                                  Height="34"
                                  FontSize="15"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="LAB-1"/>
                            <ComboBoxItem Content="LAB-2"/>
                            <ComboBoxItem Content="LAB-3"/>
                            <ComboBoxItem Content="LAB-4"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                        <TextBlock Text="Statystyki"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   Margin="0, 0, 0, 50"/>

                        <TextBlock Text="Mężczyźni: 0"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="Bold"/>

                        <TextBlock Text="Kobiety: 0"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="Bold"/>

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>