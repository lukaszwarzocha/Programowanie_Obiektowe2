<Window x:Class="Projekt_PO_KW.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projekt_PO_KW.Views"
        mc:Ignorable="d"
        Title="RegisterWindow" Height="500" Width="800">
    <Grid Background="#FFEFE8E8">
        <Grid.Effect>
            <DropShadowEffect/>
        </Grid.Effect>
        <Rectangle x:Name="GlownyPanel" HorizontalAlignment="Center" VerticalAlignment="Top" Height="378" Width="470" Margin="0,51,0,0" Fill="White" Stroke="White" RadiusX="10" RadiusY="10"/>
        <Label Content="Rejestracja" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="199,60,0,0" Width="194" Height="42" FontWeight="Bold" FontSize="22"/>
        <TextBlock x:Name="EtykietaImie" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="205,110,0,0" Width="36" Height="23" FontWeight="Bold" Text="Imię"/>
        <Border CornerRadius="8" BorderBrush="#FFE5E7EB" BorderThickness="1" Background="#FFF9FAFB" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="205,136,0,0" Width="180" Height="26">
            <TextBox x:Name="PoleImie" BorderThickness="0" Background="Transparent" Padding="8,3" VerticalContentAlignment="Center"/>
        </Border>

        <TextBlock x:Name="EtykietaNazwisko" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="424,110,0,0" Width="52" Height="23" FontWeight="Bold" Text="Nazwisko"/>
        <Border CornerRadius="8" BorderBrush="#FFE5E7EB" BorderThickness="1" Background="#FFF9FAFB" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="424,136,0,0" Width="180" Height="26">
            <TextBox x:Name="PoleNazwisko" BorderThickness="0" Background="Transparent" Padding="8,3" VerticalContentAlignment="Center"/>
        </Border>


        <TextBlock x:Name="EtykietaEmail" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="205,178,0,0" Width="36" Height="23" FontWeight="Bold" Text="Email"/>
        <Border CornerRadius="8" BorderBrush="#FFE5E7EB" BorderThickness="1" Background="#FFF9FAFB" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="205,201,0,0" Width="180" Height="26">
            <TextBox x:Name="PoleEmail" BorderThickness="0" Background="Transparent" Padding="8,3" VerticalContentAlignment="Center"/>
        </Border>

        <TextBlock x:Name="EtykietaTelefon" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="424,178,0,0" Width="45" Height="23" FontWeight="Bold" Text="Telefon"/>
        <Border CornerRadius="8" BorderBrush="#FFE5E7EB" BorderThickness="1" Background="#FFF9FAFB" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="424,201,0,0" Width="180" Height="26">
            <TextBox x:Name="PoleTelefon" BorderThickness="0" Background="Transparent" Padding="8,3" VerticalContentAlignment="Center"/>
        </Border>

        <TextBlock x:Name="EtykietaAdres" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="205,240,0,0" Width="105" Height="23">
        <Run Text="Adres " FontWeight="Bold"/>
        <Run Text="(opcjonalne)" Foreground="#FF9CA3AF" FontWeight="Normal" FontSize="12"/>
        </TextBlock>

        <Border CornerRadius="8" BorderBrush="#FFE5E7EB" BorderThickness="1" Background="#FFF9FAFB"  HorizontalAlignment="Left" VerticalAlignment="Top" Margin="205,268,0,0" Width="399" Height="26">
            <TextBox x:Name="PoleAdres" BorderThickness="0" Background="Transparent" Padding="8,3" VerticalContentAlignment="Center"/>
        </Border>

        <TextBlock x:Name="EtykietaHaslo" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="205,311,0,0" Width="36" Height="22" FontWeight="Bold" Text="Hasło"/>
        <Border CornerRadius="8" BorderBrush="#FFE5E7EB" BorderThickness="1" Background="#FFF9FAFB" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="205,338,0,0" Width="180" Height="26">
            <PasswordBox x:Name="PoleHaslo" BorderThickness="0" Background="Transparent" Padding="8,3" VerticalContentAlignment="Center"/>
        </Border>

        <TextBlock x:Name="EtykietaPotwierdzHaslo" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="424,311,0,0" Width="90" Height="22" FontWeight="Bold" Text="Potwierdź hasło"/>
        <Border CornerRadius="8" BorderBrush="#FFE5E7EB" BorderThickness="1" Background="#FFF9FAFB" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="424,338,0,0" Width="180" Height="26">
            <PasswordBox x:Name="PolePotwierdzHaslo" BorderThickness="0" Background="Transparent" Padding="8,3" VerticalContentAlignment="Center"/>
        </Border>

        <Button Content="Powróć do logowania" HorizontalAlignment="Left" VerticalAlignment="Top"  Margin="205,387,0,0" Width="123" Height="28" Click="WrocDoLogowania" Background="White" BorderBrush="White" 
        FontWeight="Bold" BorderThickness="0" Foreground="#FFFB7185"/>
        <Label Content="lub" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="370,387,0,0" Width="28" Height="24" Foreground="#FF9CA3AF"/>

        <Button Content="Zarejestruj się" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="424,389,0,0" Width="180" Height="28" Click="Zarejestruj" Background="#FFFB7185" BorderBrush="#FFFB7185" 
        FontWeight="Bold" BorderThickness="0" Foreground="White">

            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="8" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

    </Grid>
</Window>