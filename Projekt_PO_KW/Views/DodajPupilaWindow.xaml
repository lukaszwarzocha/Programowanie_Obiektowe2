<Window x:Class="Projekt_PO_KW.Views.DodajPupilaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projekt_PO_KW.Views"
        mc:Ignorable="d"
        Title="Dodaj Pupila" Height="520" Width="400"
        ResizeMode="NoResize">
    <Grid Background="White">
        <Border Background="White" Margin="20,20,20,0">
            <StackPanel Margin="30,25,30,10">

                <TextBlock Text="Dodaj Pupila" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                <TextBlock Text="Imię" FontWeight="Bold" Margin="0,0,0,5"/>
                <Border CornerRadius="8" BorderBrush="#FFE5E7EB" BorderThickness="1"
                        Background="#FFF9FAFB" Height="32" Margin="0,0,0,15">
                    <TextBox x:Name="PupilImie" BorderThickness="0" Background="Transparent" Padding="8,4"/>
                </Border>

                <TextBlock Text="Gatunek" FontWeight="Bold" Margin="0,0,0,5"/>
                <Border BorderBrush="#FFE5E7EB"  Height="31" Width="300">
                    <ComboBox x:Name="PupilGatunek" BorderThickness="1" Margin="3,2,20,1">
                        <ComboBoxItem Content="Pies"/>
                        <ComboBoxItem Content="Kot"/>
                    </ComboBox>
                </Border>

                <TextBlock Text="Rasa" FontWeight="Bold" Margin="0,10,0,5"/>
                <Border CornerRadius="8" BorderBrush="#FFE5E7EB" BorderThickness="1"
                        Background="#FFF9FAFB" Height="32" Margin="0,0,0,15">
                    <TextBox x:Name="PupilRasa" BorderThickness="0" Background="Transparent" Padding="8,4"/>
                </Border>

                <TextBlock Text="Wiek (lata)" FontWeight="Bold" Margin="0,0,0,5"/>
                <Border CornerRadius="8" BorderBrush="#FFE5E7EB" BorderThickness="1"
                        Background="#FFF9FAFB" Height="32" Margin="0,0,0,25">
                    <TextBox x:Name="PupilWiek" BorderThickness="0" Background="Transparent" Padding="8,4"/>
                </Border>

                <TextBlock Text="Płeć" FontWeight="Bold" Margin="0,0,0,5"/>
                <Border BorderBrush="#FFE5E7EB"  Height="31" Width="300">
                    <ComboBox x:Name="PupilPlec" BorderThickness="1" Margin="3,2,20,1">
                        <ComboBoxItem Content="Samiec"/>
                        <ComboBoxItem Content="Samica"/>
                    </ComboBox>
                </Border>

                <Button Content="Dodaj Pupila" Height="36" Click="Dodaj_Pupila" Margin="0,10,0,0"
                        Background="#FFFB7185" Foreground="White"
                        BorderThickness="0" FontWeight="Bold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>